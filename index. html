
<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Gang Joker Digital</title>

<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&display=swap" rel="stylesheet">

<style>

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  font-family:'Nunito',sans-serif;
  background:#33b5e8;
  min-height:100vh;
  display:flex;
  justify-content:center;
  align-items:center;
  padding:25px;
}

.container{
  width:100%;
  max-width:500px;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:25px;
}

/* Logo */
.logo{
  width:170px;
  height:170px;
  object-fit:cover;
  border-radius:50%;
  border:5px solid #ffffff;
  box-shadow:0 8px 25px rgba(0,0,0,.2);
}

/* Judul */
.title{
  color:white;
  text-align:center;
  font-size:2.3rem;
  font-weight:900;
  line-height:1.2;
  text-transform:uppercase;
}

/* Sub Judul */
.subtitle{
  color:white;
  text-align:center;
  font-size:.95rem;
  opacity:.95;
  margin-top:-10px;
}

/* Card */
.card{
  width:100%;
  background:#fffdf6;
  border-radius:24px;
  padding:22px;
  box-shadow:0 8px 30px rgba(0,0,0,.12);
}

.card-label{
  display:inline-block;
  background:#e8825a;
  color:white;
  font-size:.8rem;
  font-weight:900;
  letter-spacing:1px;
  padding:8px 18px;
  border-radius:30px;
  margin-bottom:18px;
}

/* Tombol */
.card-btn{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:10px;

  width:100%;
  padding:18px;

  text-decoration:none;
  color:white;

  background:#2d4a8a;
  border-radius:15px;

  font-size:1rem;
  font-weight:900;

  transition:.2s;
}

.card-btn:hover{
  transform:translateY(-2px);
}

.btn-icon{
  font-size:1.3rem;
}

/* Footer */
.footer{
  color:white;
  text-align:center;
  font-size:.8rem;
  opacity:.9;
  margin-top:10px;
}

</style>
</head>
<body>

<div class="container">

  <!-- LOGO -->
  <img src="img/joker.jpg" alt="Gang Joker Digital" class="logo">

  <!-- JUDUL -->
  <h1 class="title">
    Gang Joker<br>
    Digital
  </h1>

  <div class="subtitle">
    Sistem Kas & Lumbung Pangan Digital
  </div>

  <!-- KAS -->
  <div class="card">

    <div class="card-label">
      Kas Gang Joker
    </div>

    <a class="card-btn"
       href="Kas_Gang_Joker.html">

      <span class="btn-icon">🃏</span>
      Buka Kas Gang Joker

    </a>

  </div>

  <!-- LUMBUNG PANGAN -->
  <div class="card">

    <div class="card-label">
      Lumbung Pangan RT
    </div>

    <a class="card-btn"
       href="LP-Ulti.html">

      <span class="btn-icon">🌾</span>
      Buka Lumbung Pangan RT

    </a>

  </div>

  <div class="footer">
    © Gang Joker Digital
  </div>

</div>

</body>
</html>
